# Google Sheets API credentials (create at console.cloud.google.com)
GOOGLE_CREDENTIALS_FILE=credentials.json

# Google Sheet ID (from the URL: docs.google.com/spreadsheets/d/THIS_PART/edit)
SPREADSHEET_ID=your_spreadsheet_id_here

# Sheet names
LEADS_SHEET=Leads
PROCESSED_SHEET=Processed
ANALYTICS_SHEET=Analytics

# AI Provider: "openai" or "ollama"
AI_PROVIDER=openai

# OpenAI API Key (if using openai provider)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Ollama (if using ollama provider)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Processing settings
BATCH_SIZE=10
POLL_INTERVAL=300
